{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "argocd": {
    "fileMatch": ["(^|/)apps/[^/]+\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": ["(^|/)apps/.+/deployment\\.yaml$"]
  },
  "packageRules": [
    {
      "matchManagers": ["argocd", "kubernetes"],
      "addLabels": ["renovate"]
    },
    {
      "matchPackagePatterns": ["^lscr\\.io/linuxserver/"],
      "versioning": "loose",
      "allowedVersions": "!/nightly/"
    },
    {
      "matchPackagePatterns": ["^lscr\\.io/linuxserver/qbittorrent$"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}
